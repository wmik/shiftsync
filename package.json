{
  "name": "shiftsync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "test": "jest",
    "test:run": "jest --runInBand",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "playwright test --reporter=html",
    "db:test:setup": "cp __tests__/.env.test .env && npx prisma migrate deploy",
    "db:test:seed": "cp __tests__/.env.test .env && npx tsx prisma/seed.ts",
    "db:test:reset": "cp __tests__/.env.test .env && npx prisma migrate reset --force"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@better-auth/prisma-adapter": "^1.5.6",
    "@prisma/adapter-pg": "^7.6.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@prisma/client": "^7.6.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
